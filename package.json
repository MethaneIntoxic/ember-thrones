{
  "name": "ember-thrones",
  "private": true,
  "version": "0.1.0",
  "description": "Local-only dragon-themed hold-and-respin slot game",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @ember-thrones/server\" \"npm run dev -w @dragon-link/client\"",
    "dev:server": "npm run dev -w @ember-thrones/server",
    "dev:client": "npm run dev -w @dragon-link/client",
    "desktop:local": "npm run dev",
    "mobile:pwa:dev": "npm run dev:pwa -w @dragon-link/client",
    "mobile:pwa:preview": "npm run preview:pwa -w @dragon-link/client",
    "mobile:pwa:build": "npm run build -w @dragon-link/client",
    "publish:pages": "powershell -ExecutionPolicy Bypass -File ./run-publish-pages.ps1",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "sim": "npm run sim -w @ember-thrones/shared"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
