{
  "name": "@ember-thrones/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "prebuild": "npm --prefix ../../packages/shared run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm --prefix ../../packages/shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm --prefix ../../packages/shared run build",
    "test": "tsx --test tests/**/*.test.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@ember-thrones/shared": "file:../../packages/shared",
    "@fastify/cors": "^10.1.0",
    "better-sqlite3": "^12.1.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
