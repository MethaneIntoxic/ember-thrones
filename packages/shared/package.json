{
  "name": "@ember-thrones/shared",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Shared deterministic domain and contracts for Ember Thrones",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "vitest run tests/shared.spec.ts --testNamePattern simulation"
  },
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
